{
    "version": "0.2.0",
    "configurations": [
        {
            // macOS / Linux — CodeLLDB (vadimcn.vscode-lldb)
            "type": "lldb",
            "request": "launch",
            "name": "Debug 'rsbasic' (LLDB – macOS/Linux)",
            "preLaunchTask": "cargo build (rsbasic)",
            "program": "${workspaceFolder}/target/debug/rsbasic",
            "args": [],
            "cwd": "${workspaceFolder}",
            "terminal": "integrated"
        },
        {
            // Windows (MSVC) — Microsoft C/C++ (ms-vscode.cpptools)
            "type": "cppvsdbg",
            "request": "launch",
            "name": "Debug 'rsbasic' (Windows MSVC)",
            "preLaunchTask": "cargo build (rsbasic)",
            "program": "${workspaceFolder}/target/debug/rsbasic.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal"
        }
    ]
}
